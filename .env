# ============================================
# POLYTRADER CLONE - Configuration
# ============================================
# Copy this to .env and fill in your values

# Trading Mode: "paper" (default, safe) or "live"
TRADING_MODE=paper

# Wallet Configuration
PRIVATE_KEY=your_private_key_here
POLYMARKET_PROXY_ADDRESS=your_proxy_wallet_address
SIGNATURE_TYPE=1  # 1=email/Magic, 2=browser wallet, 0=EOA

# Bankroll
LIVE_BANKROLL=100
PAPER_BANKROLL=1000
BET_SIZE_PERCENT=5  # % of bankroll per trade

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Leaderboard Scanner
SCAN_INTERVAL_HOURS=24
MIN_WIN_RATE=55
MIN_VOLUME_USD=5000
MAX_CRYPTO_RATIO=0.4
PREFERRED_CATEGORIES=politics,economics,science,entertainment,finance
LEADERS_PER_CATEGORY=10
MAX_LEADERS=10

# Trade Monitor
POLL_INTERVAL_SECONDS=30

# Guards
MIN_MARKET_LIQUIDITY=5000
MAX_SPREAD_PERCENT=10
MIN_ODDS=0.05
MAX_ODDS=0.95

# Portfolio Management
TRAILING_STOP_PERCENT=15
CASHOUT_THRESHOLD=0.98
PROFIT_SKIM_PERCENT=0
PROFIT_SKIM_WALLET=

# Dashboard
DASHBOARD_PORT=8502
